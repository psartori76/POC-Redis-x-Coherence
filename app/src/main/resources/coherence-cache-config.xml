<?xml version="1.0"?>
<cache-config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xmlns="http://xmlns.oracle.com/coherence/coherence-cache-config"
              xsi:schemaLocation="http://xmlns.oracle.com/coherence/coherence-cache-config coherence-cache-config.xsd">
  <caching-scheme-mapping>
    <!--
      O NamedMap "products" usado no Java e ligado ao esquema distributed-cache.
      Quando a app chama session.getMap("products"), ela recebe esse cache.
    -->
    <cache-mapping>
      <cache-name>products</cache-name>
      <scheme-name>distributed-cache</scheme-name>
    </cache-mapping>
  </caching-scheme-mapping>

  <caching-schemes>
    <!--
      Cache distribuido do Coherence para a POC. O no app-bastion participa do
      cluster com localstorage=false, entao acessa o mapa sem guardar particoes.
      A VM Coherence atua como storage node e guarda os dados.
    -->
    <distributed-scheme>
      <scheme-name>distributed-cache</scheme-name>
      <service-name>ProductsDistributedCache</service-name>
      <backing-map-scheme>
        <local-scheme>
          <!-- Expiracao alinhada ao TTL do Redis para facilitar a comparacao. -->
          <expiry-delay>5m</expiry-delay>
        </local-scheme>
      </backing-map-scheme>
      <autostart>true</autostart>
    </distributed-scheme>
  </caching-schemes>
</cache-config>
