#cloud-config
package_update: true
packages:
  - java-17-openjdk
  - jq
  - tmux
  - unzip
  - wget
  - curl
runcmd:
  - mkdir -p /opt/poc/app
  - systemctl enable --now sshd
  - |
    if systemctl is-active --quiet firewalld; then
      timeout 20s firewall-cmd --permanent --add-port=8080/tcp || true
      timeout 20s firewall-cmd --reload || true
    fi
  - echo "App-bastion ready for POC Coherence/Redis demo" > /etc/motd
